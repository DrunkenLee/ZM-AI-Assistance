PORT=3000
NODE_ENV=development
RCON_HOST=127.0.0.1
RCON_PORT=27020
SERVER_STATUS_HOST=127.0.0.1
SERVER_STATUS_PORTS=16261,27020
SERVER_STATUS_TIMEOUT_MS=2500
SERVER_STATUS_ATTEMPTS=2
DEV_WORKSHOP_PATH=C:\PZServer\steamapps\workshop\content\108600
LIVE_WORKSHOP_PATH=latertobedetirmine
WORKSHOP_LOOKUP_ENABLED=true
WORKSHOP_LOOKUP_MAX_FILES=2000
WORKSHOP_LOOKUP_MAX_FILE_SIZE_BYTES=524288
WORKSHOP_LOOKUP_TOP_K=5
WORKSHOP_LOOKUP_EXCERPT_CHARS=500
WORKSHOP_LOOKUP_KNOWLEDGE_FIRST_ONLY=true
INTERNET_LOOKUP_ENABLED=true
INTERNET_LOOKUP_TOP_K=4
INTERNET_LOOKUP_TIMEOUT_MS=7000

# OpenAI settings
AI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-4o-mini
AI_VECTOR_ENABLED=true
OPENAI_VECTOR_STORE_IDS=vs_xxx,vs_yyy
AI_VECTOR_TOP_K=5
AI_MAX_TOKENS=1200
AI_CASUAL_MAX_TOKENS=300
AI_OPERATIONAL_MAX_TOKENS=180
AI_TEMPERATURE=1
# gpt-5 reasoning effort: minimal | low | medium | high (lower = more reliable
# visible answers). Ignored by non-gpt-5 models such as gpt-4o-mini.
AI_REASONING_EFFORT=low
AI_ENABLED=true

# DB mode selection: remote | prod
DB_TARGET=remote
DB_SSL=false

# Preferred full URLs
DATABASE_URL_REMOTE=postgresql://user:password@host:5432/dbname
DATABASE_URL_PROD=postgresql://user:password@host:5432/dbname

# Fallback discrete DB fields
PGHOSTREMOTE=127.0.0.1
PGHOSTPROD=127.0.0.1
PGPORT=5432
PGDATABASE=app_db
PGUSER=postgres
PGPASSWORD=postgres

JWT_SECRET=change_me
AUTH_TOKEN_EXPIRES_IN=1h

# Discord listener for AI prompts (separate process)
DISCORD_BOT_TOKEN=
AllowedChannelIDs=
DISCORD_AI_PROMPT_PREFIX=?
DISCORD_LISTENER_WITH_SERVER=true
DISCORD_DAILY_PROMPT_LIMIT=10
DISCORD_ADMIN_BYPASS_ENABLED=true
DISCORD_NOTIFY_DISALLOWED_CHANNEL=true
DISCORD_LOG_IGNORED_PROMPTS=true
DISCORD_ADMIN_ROLE_NAMES=admin
DISCORD_ADMIN_ROLE_IDS=
